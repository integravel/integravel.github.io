      { "id": "4", "tex": "\\( a = 2k \\)" },
      { "id": "5", "tex": "\\( b^2 = 2k^2 \\)" },
      { "id": "6", "tex": "\\( b \\text{ é par} \\)" }
    ],
    "fim": [
      "Contradição.",
      "Logo, \\( \\sqrt{2} \\) é irracional."
